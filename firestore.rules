rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidPostIdeaLink(data) {
      return data.keys().hasAll(['url', 'title', 'createdAt', 'status'])
        && data.url is string && data.url.size() > 0 && data.url.size() <= 2048
        && data.title is string && data.title.size() <= 500
        && data.status is string && (data.status == 'pending' || data.status == 'drafted' || data.status == 'published')
        && (data.createdAt is string || data.createdAt is timestamp)
        && (!('description' in data) || data.description is string)
        && (!('image' in data) || data.image is string)
        && (!('siteName' in data) || data.siteName is string)
        && (!('notes' in data) || data.notes is string)
        && (!('aiSummary' in data) || data.aiSummary is string)
        && (!('tags' in data) || data.tags is list);
    }

    match /post_ideas/{ideaId} {
      allow read: if true;
      allow create: if isValidId(ideaId) && isValidPostIdeaLink(request.resource.data);
      allow update: if isValidId(ideaId) && isValidPostIdeaLink(request.resource.data);
      allow delete: if isValidId(ideaId);
    }

    match /test/{docId} {
      allow read: if true;
    }
  }
}
